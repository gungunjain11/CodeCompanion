{
  "manifest_version": 3,
  "name": "ModelMirror — Code Companion",
  "description": "AI-powered coding companion. Explain, refactor, optimize, and generate tests for any code — right in your browser.",
  "version": "1.1.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "sidePanel",
    "scripting",
    "activeTab",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open ModelMirror",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
